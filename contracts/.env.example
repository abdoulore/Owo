# Read natively by Foundry (foundry.toml's rpc_endpoints/etherscan, and
# Deploy.s.sol's vm.envUint/vm.envOr) -- Foundry only looks in this directory,
# never the repo root, so this file has to exist here even though api/.env
# duplicates the same RPC and relayer key.
ARBITRUM_SEPOLIA_RPC=
RELAYER_PRIVATE_KEY=
ARBISCAN_API_KEY=

# Optional: set only if deploying against a real USDC instead of MockUSDC.
USDC_ADDRESS=
